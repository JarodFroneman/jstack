            "from typing import Dict",
            "",
            "SYNTHETIC_EXPORTS: Dict[str, str] = {\"tenant-a\": \"alpha\", \"tenant-b\": \"bravo\"}",
            "",
            "def export_for(caller_tenant: str, requested_tenant: str) -> str:",
            "    if not caller_tenant:",
            "        raise ValueError(\"caller tenant required\")",
            "    # Defect: requested_tenant is not compared with caller_tenant.",
            "    return SYNTHETIC_EXPORTS[requested_tenant]",
