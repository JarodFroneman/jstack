{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jstack.dev/schemas/external-action-approval-request.v1.schema.json",
  "title": "JStack private local external-action approval request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "authorizationId",
    "challengeDigest",
    "encodedPayload",
    "signatureAlgorithm",
    "keyEnvironment",
    "approverId",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "jstack.external-action.approval-request.v1"
    },
    "authorizationId": {
      "type": "string",
      "pattern": "^authorization-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{12}$"
    },
    "challengeDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "encodedPayload": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100000
    },
    "signatureAlgorithm": {
      "const": "HMAC-SHA256"
    },
    "keyEnvironment": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{2,100}$"
    },
    "approverId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
