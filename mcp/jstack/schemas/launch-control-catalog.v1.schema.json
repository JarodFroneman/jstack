{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jstack.local/schemas/launch-control-catalog.v1.schema.json",
  "title": "JStack Launch Control Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "catalogVersion", "sourceProvenance", "surfaces", "statuses", "evidenceKinds", "controls"],
  "properties": {
    "schemaVersion": {"const": "jstack.launch.controls.v1"},
    "catalogVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "sourceProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceUrl", "reviewedAt", "adaptationNotice"],
      "properties": {
        "sourceUrl": {"type": "string", "pattern": "^https://", "maxLength": 1000},
        "reviewedAt": {"type": "string", "format": "date"},
        "adaptationNotice": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": {"$ref": "#/$defs/surface"},
          "description": {"type": "string", "minLength": 1, "maxLength": 500}
        }
      }
    },
    "statuses": {
      "const": ["pass", "fail", "incomplete", "not-applicable", "waived"]
    },
    "evidenceKinds": {
      "const": ["automated-test", "browser-test", "code-review", "configuration-snapshot", "delivery-test", "human-attestation", "legal-document", "manual-test", "monitoring-report", "performance-report", "provider-receipt", "security-scan"]
    },
    "controls": {
      "type": "array",
      "minItems": 37,
      "maxItems": 37,
      "items": {"$ref": "#/$defs/control"}
    }
  },
  "$defs": {
    "surface": {
      "type": "string",
      "enum": ["core", "public-web", "browser-ui", "authenticated", "database", "transactional-email", "search-indexed", "performance-sensitive", "analytics", "payments", "commercial", "tracking", "ai-paid-endpoints", "regulated-data"]
    },
    "evidenceKind": {
      "type": "string",
      "enum": ["automated-test", "browser-test", "code-review", "configuration-snapshot", "delivery-test", "human-attestation", "legal-document", "manual-test", "monitoring-report", "performance-report", "provider-receipt", "security-scan"]
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sequence", "category", "title", "objective", "sourcePriority", "gateLevel", "applicability", "evidenceKinds", "verificationMethods", "maxAgeMinutes", "ownerRole", "waivable", "allowNotApplicable", "safetyNotes"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,79}$"},
        "sequence": {"type": "integer", "minimum": 1, "maximum": 37},
        "category": {"type": "string", "enum": ["security", "email", "findability", "speed", "analytics", "legal", "final-test"]},
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "objective": {"type": "string", "minLength": 1, "maxLength": 1000},
        "sourcePriority": {"type": "string", "enum": ["blocker", "first-week", "nice-to-have"]},
        "gateLevel": {"type": "string", "enum": ["blocker", "required", "advisory"]},
        "applicability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allOf", "anyOf"],
          "properties": {
            "allOf": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/surface"}},
            "anyOf": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/surface"}}
          }
        },
        "evidenceKinds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/evidenceKind"}},
        "verificationMethods": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 500}},
        "maxAgeMinutes": {"type": "integer", "minimum": 1, "maximum": 1440},
        "ownerRole": {"type": "string", "enum": ["lead", "architect", "builder", "reviewer", "qa", "security", "devops", "product", "docs", "legal-owner", "business-owner"]},
        "waivable": {"type": "boolean"},
        "allowNotApplicable": {"type": "boolean"},
        "safetyNotes": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    }
  }
}
