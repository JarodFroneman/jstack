{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jstack.local/schemas/launch-evidence.v1.schema.json",
  "title": "JStack Launch Evidence Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "projectPath", "gitHead", "projectFingerprint", "baseCommit", "policyDigest", "toolVersion", "catalogVersion", "catalogDigest", "selectionDigest", "launchSessionDigest", "controlId", "category", "gateLevel", "evidenceKind", "outcome", "verifier", "sourceReferenceDigest", "summaryDigest", "artifactSha256", "artifactSize", "artifactPathDigest", "artifactRootKind", "observedAt", "expiresAt", "passed", "serverSession", "issuedAt"],
  "properties": {
    "kind": {"const": "launch-evidence"},
    "schemaVersion": {"const": "jstack.launch.evidence.v1"},
    "projectPath": {"type": "string", "minLength": 1},
    "gitHead": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "projectFingerprint": {"$ref": "#/$defs/sha256"},
    "baseCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "policyDigest": {"$ref": "#/$defs/sha256"},
    "toolVersion": {"type": "string", "minLength": 1},
    "catalogVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "catalogDigest": {"$ref": "#/$defs/sha256"},
    "selectionDigest": {"$ref": "#/$defs/sha256"},
    "launchSessionDigest": {"$ref": "#/$defs/sha256"},
    "controlId": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,79}$"},
    "category": {"type": "string", "enum": ["security", "email", "findability", "speed", "analytics", "legal", "final-test"]},
    "gateLevel": {"type": "string", "enum": ["blocker", "required", "advisory"]},
    "evidenceKind": {"type": "string", "enum": ["automated-test", "browser-test", "code-review", "configuration-snapshot", "delivery-test", "human-attestation", "legal-document", "manual-test", "monitoring-report", "performance-report", "provider-receipt", "security-scan"]},
    "outcome": {"type": "string", "enum": ["pass", "fail", "incomplete", "not-applicable"]},
    "verifier": {"type": "string", "minLength": 1, "maxLength": 200},
    "sourceReferenceDigest": {"$ref": "#/$defs/sha256"},
    "summaryDigest": {"$ref": "#/$defs/sha256"},
    "artifactSha256": {"$ref": "#/$defs/sha256"},
    "artifactSize": {"type": "integer", "minimum": 0, "maximum": 100000000},
    "artifactPathDigest": {"$ref": "#/$defs/sha256"},
    "artifactRootKind": {"type": "string", "enum": ["project", "external-evidence"]},
    "observedAt": {"type": "string", "format": "date-time"},
    "expiresAt": {"type": "string", "format": "date-time"},
    "passed": {"type": "boolean"},
    "serverSession": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "issuedAt": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
