{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jstack.local/schemas/launch-result.v1.schema.json",
  "title": "JStack Launch Final Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "projectPath", "gitHead", "projectFingerprint", "baseRef", "baseCommit", "policyDigest", "toolVersion", "catalogVersion", "catalogDigest", "selectionDigest", "targetEnvironment", "targetUrl", "surfaces", "profileOwner", "profileReferenceDigest", "controlResults", "activeWaivers", "complete", "passed", "expiresAt", "serverSession", "issuedAt"],
  "properties": {
    "kind": {"const": "launch"},
    "schemaVersion": {"const": "jstack.launch.receipt.v1"},
    "projectPath": {"type": "string", "minLength": 1},
    "gitHead": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "projectFingerprint": {"$ref": "#/$defs/sha256"},
    "baseRef": {"type": "string", "minLength": 1},
    "baseCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "policyDigest": {"$ref": "#/$defs/sha256"},
    "toolVersion": {"type": "string", "minLength": 1},
    "catalogVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "catalogDigest": {"$ref": "#/$defs/sha256"},
    "selectionDigest": {"$ref": "#/$defs/sha256"},
    "targetEnvironment": {"type": "string", "minLength": 2, "maxLength": 64},
    "targetUrl": {"type": ["string", "null"], "maxLength": 2000},
    "surfaces": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "profileOwner": {"type": "string", "minLength": 1, "maxLength": 200},
    "profileReferenceDigest": {"$ref": "#/$defs/sha256"},
    "controlResults": {
      "type": "array",
      "minItems": 1,
      "maxItems": 37,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["controlId", "sequence", "category", "gateLevel", "status", "evidenceReceiptDigest", "waiverDigest"],
        "properties": {
          "controlId": {"type": "string"},
          "sequence": {"type": "integer", "minimum": 1, "maximum": 37},
          "category": {"type": "string"},
          "gateLevel": {"type": "string", "enum": ["blocker", "required", "advisory"]},
          "status": {"type": "string", "enum": ["pass", "fail", "incomplete", "not-applicable", "waived"]},
          "evidenceReceiptDigest": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
          "waiverDigest": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}
        }
      }
    },
    "activeWaivers": {"type": "array", "maxItems": 37, "items": {"type": "object"}},
    "complete": {"type": "boolean"},
    "passed": {"type": "boolean"},
    "expiresAt": {"type": "string", "format": "date-time"},
    "serverSession": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "issuedAt": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
