{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jstack.local/schemas/specialist-result.v1.schema.json",
  "title": "JStack Specialist Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "scopeHandled",
    "evidence",
    "findings",
    "changes",
    "blockers",
    "residualRisk",
    "skippedChecks",
    "recommendedNextAction"
  ],
  "properties": {
    "schemaVersion": {
      "const": "jstack.specialist.result.v1"
    },
    "status": {
      "enum": ["success", "partial", "blocked", "error"]
    },
    "scopeHandled": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "changes": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/change"
      }
    },
    "blockers": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "$ref": "#/$defs/blocker"
      }
    },
    "residualRisk": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "skippedChecks": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "$ref": "#/$defs/skippedCheck"
      }
    },
    "recommendedNextAction": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "maxLength": 100
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"
    },
    "reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "status", "summary", "references"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/identifier"
        },
        "status": {
          "enum": ["observed", "passed", "failed", "not-run", "unavailable"]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "references": {
          "type": "array",
          "minItems": 1,
          "maxItems": 30,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "verifier": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "$ref": "#/$defs/repositoryPath"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingId",
        "resolutionKey",
        "disposition",
        "severity",
        "confidence",
        "title",
        "claim",
        "evidenceKinds"
      ],
      "properties": {
        "findingId": {
          "$ref": "#/$defs/identifier"
        },
        "resolutionKey": {
          "$ref": "#/$defs/identifier"
        },
        "disposition": {
          "enum": ["pass", "concern", "block", "not-applicable"]
        },
        "severity": {
          "enum": ["info", "low", "medium", "high", "critical"]
        },
        "confidence": {
          "enum": ["low", "medium", "high"]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "claim": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3000
        },
        "evidenceKinds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "location": {
          "$ref": "#/$defs/location"
        }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "summary"],
      "properties": {
        "path": {
          "$ref": "#/$defs/repositoryPath"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "summary", "approvalRequired"],
      "properties": {
        "code": {
          "$ref": "#/$defs/identifier"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "approvalRequired": {
          "type": "boolean"
        }
      }
    },
    "skippedCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check", "reason", "impact"],
      "properties": {
        "check": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "impact": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  }
}
